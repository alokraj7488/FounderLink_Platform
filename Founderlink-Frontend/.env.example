# FounderLink Frontend — Environment Variables
# Copy this file to .env and fill in your values

# ── API Base URL ─────────────────────────────────────────
# Backend API Gateway URL (local development default)
VITE_API_BASE_URL=http://localhost:8080

# ── WebSocket URL ────────────────────────────────────────
# MessagingService WebSocket endpoint (local development default)
VITE_WS_URL=http://localhost:8086/ws
